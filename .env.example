# =============================================================================
# AZ Pickleball Partner Finder — credentials & config
# =============================================================================
# Copy this file to ".env" (same folder) and fill in your OWN account
# credentials for the login-gated sources. The app reads them at runtime to
# authenticate as you and pull data. This file is git-ignored; keep it private.
#
# Leave any credential BLANK to skip that source's authenticated fetch — the
# app will just show a "not configured" status for it instead of erroring.
# =============================================================================

# --- Your profile ----------------------------------------------------------
# Used for partner matching and distance math. HOME_LAT/LNG can be your city
# center (find them on Google Maps). Sweet-spot band defaults to rating ±0.5.
MY_NAME=Your Name
MY_DUPR_DOUBLES=4.5
MY_DUPR_SINGLES=4.5
HOME_BASE=Phoenix, AZ
HOME_LAT=33.4484
HOME_LNG=-112.0740
#RATING_SWEET_LOW=4.0
#RATING_SWEET_HIGH=5.0

# --- DUPR (dashboard.dupr.com) — your DUPR login -----------------------------
DUPR_EMAIL=you@example.com
DUPR_PASSWORD=

# --- PickleMoneyBall (app.picklemoneyball.com) — your PMB login ---------------
PMB_EMAIL=you@example.com
PMB_PASSWORD=
# The PMB web app's client function key: log in at app.picklemoneyball.com with
# your browser's network tab open and copy the "x-functions-key" request header
# from the Login call. Needed only for your own sign-up status.
PMB_FUNC_KEY=

# --- APP Tour / PickleballDen (app.pickleballden.com) — your login -----------
PBDEN_EMAIL=you@example.com
PBDEN_PASSWORD=

# =============================================================================
# Optional tuning (safe defaults are used if left blank)
# =============================================================================
# Seconds to wait between requests to the same host (politeness throttle)
FETCH_MIN_DELAY_SECONDS=2
# Your identifying User-Agent for polite fetching
FETCH_USER_AGENT=AZ-PB-Partner-Finder/1.0 (personal research tool)
